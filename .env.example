# Required for real LLM runs through your OpenAI-compatible MCP gateway
MCP_API_BASE=https://your-openai-compatible-endpoint/v1
MCP_API_KEY=sk-...
MCP_MODEL=gpt-5.4

# Optional compatibility fallbacks; MCP_* is preferred by default
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-5.4

# Langfuse is enabled by default when these are set
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_BASE_URL=https://cloud.langfuse.com
# For US region, use: https://us.cloud.langfuse.com
